# Gate.io API配置
GATE_API_KEY=your_api_key_here
GATE_SECRET_KEY=your_secret_key_here
GATE_SANDBOX=true

# 数据库配置
DATABASE_URL=sqlite:///data/trading.db

# 飞书通知配置
# 在飞书群中添加自定义机器人，获取webhook URL
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id

# 交易参数
INITIAL_CAPITAL=10
LEVERAGE=20
STOP_LOSS_PCT=3
TAKE_PROFIT_PCT=6